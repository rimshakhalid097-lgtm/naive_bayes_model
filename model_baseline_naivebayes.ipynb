_text.shape[0])\\n\",","    \"print(\\\"Validation size:\\\", X_val_text.shape[0])\\n\",","    \"\\n\",","    \"# --- Vectorizer ---\\n\",","    \"vectorizer = TfidfVectorizer(max_features=30000, ngram_range=(1,2), min_df=2)\\n\",","    \"X_train = vectorizer.fit_transform(X_train_text)\\n\",","    \"X_val   = vectorizer.transform(X_val_text)\\n\",","    \"\\n\",","    \"# --- Train baseline model ---\\n\",","    \"nb = MultinomialNB(alpha=1.0)\\n\",","    \"nb.fit(X_train, y_train)\\n\",","    \"\\n\",","    \"# --- Evaluate on validation set ---\\n\",","    \"y_pred = nb.predict(X_val)\\n\",","    \"acc = accuracy_score(y_val, y_pred)\\n\",","    \"print(f\\\"\\\\nBaseline model performance on validation set:\\\")\\n\",","    \"print(f\\\"Accuracy: {acc:.4f}\\\\n\\\")\\n\",","    \"print(\\\"Classification report:\\\")\\n\",","    \"print(classification_report(y_val, y_pred, digits=4))\\n\",","    \"\\n\",","    \"# --- Save model + vectorizer ---\\n\",","    \"save_path = r\\\"C:\\\\py_projects\\\\semeval-task9-ai-project\\\\nb_tfidf_combo.joblib\\\"\\n\",","    \"joblib.dump({'model': nb, 'vectorizer': vectorizer}, save_path)\\n\",","    \"print(f\\\"Baseline model and vectorizer saved to {save_path}\\\")\\n\"","   ]","  },","  {","   \"cell_type\": \"code\",","   \"execution_count\": 11,","   \"id\": \"d850e50b\",","   \"metadata\": {},","   \"outputs\": [","    {","     \"name\": \"stdout\",","     \"output_type\": \"stream\",","     \"text\": [","      \"=== TRAINING IMPROVED MODEL — LinearSVC ===\\n\",","      \"\\n\",","      \"Improved Model Accuracy: 0.7187\\n\",","      \"\\n\",","      \"Classification Report:\\n\",","      \"              precision    recall  f1-score   support\\n\",","      \"\\n\",","      \"           0       0.73      0.75      0.74      2896\\n\",","      \"           1       0.70      0.68      0.69      2479\\n\",","      \"\\n\",","      \"    accuracy                           0.72      5375\\n\",","      \"   macro avg       